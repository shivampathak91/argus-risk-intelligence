# ARGUS Platform — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Security (change in production) ───────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-hex-string

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=ARGUS Risk Intelligence Platform
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ───────────────────────────────────────────────────────────────────
# Default: SQLite file at project root
# DATABASE_URL=sqlite:///./argus.db

# ── AI Models ──────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Optional: Web Search ───────────────────────────────────────────────────────
# Get a free API key at https://tavily.com for full web search capability
# Without this, the Search MCP uses DuckDuckGo instant answers only
TAVILY_API_KEY=

# ── CORS (add your frontend URL if different) ──────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
